# Active Next.js web app
NEXT_PUBLIC_APP_NAME=Nazava Analytics

# Live Shopee export pipeline (provided automatically when Blob is linked on Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_me

# Protects /upload. Use a long, unique password.
UPLOAD_SECRET=replace-with-a-long-random-admin-password

# Optional FastAPI backend (docker-compose)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
FORECAST_DAYS=30
CONFIDENCE_INTERVAL=0.95
